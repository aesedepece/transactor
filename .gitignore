# Ignore compiled modules and executables
**/target/

# It is best practice to ignore Cargo.lock for "bin" crates, but commit it for "lib" crates
# More information here http://doc.crates.io/guide.html#cargotoml-vs-cargolock
Cargo.lock

# Ignore backup files generated by rustfmt
**/*.rs.bk

# Just in case some scatterbrain tries to commit from MacOS
.DS_Store

# Ignore auxiliar files from popular IDEs
.idea
.vscode

# Ignore log files, for the sake of privacy
*.log